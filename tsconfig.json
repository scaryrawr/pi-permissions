{
  "compilerOptions": {
    "lib": ["ES2024"],
    "erasableSyntaxOnly": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2024",
    "types": ["node"],
    "useUnknownInCatchVariables": true
  },
  "include": ["./**/*.ts"]
}
